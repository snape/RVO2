{
  "problemMatcher": [
    {
      "owner": "cpplint",
      "severity": "warning",
      "pattern": [
        {
          "regexp": "^(.+):(\\d+):\\s+(.+)\\s+\\[([^\\]]+)\\]\\s+\\[\\d+\\]$",
          "file": 1,
          "line": 2,
          "message": 3,
          "code": 4
        }
      ]
    }
  ]
}
