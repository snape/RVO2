{
  "problemMatcher": [
    {
      "owner": "detect-secrets",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^Secret Type: (.+)$",
          "message": 1
        },
        {
          "regexp": "^Location:\\s+(\\S+):(\\d+)$",
          "file": 1,
          "line": 2
        }
      ]
    }
  ]
}
